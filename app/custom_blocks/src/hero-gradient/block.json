{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "aeo-custom-blocks/hero-gradient",
  "title": "AEO Hero Gradient",
  "category": "design",
  "icon": "cover-image",
  "description": "High-converting, semantic AEO Hero Section with RichText controls.",
  "supports": {
    "html": false,
    "align": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "source": "html",
      "selector": "h1",
      "default": "Scale Your Organic Visibility"
    },
    "subtitle": {
      "type": "string",
      "source": "html",
      "selector": "p.aeo-hero-subtitle",
      "default": "Optimize your content structures for next-generation search and answer engines."
    },
    "ctaText": {
      "type": "string",
      "default": "Get Started"
    },
    "ctaUrl": {
      "type": "string",
      "default": "#"
    }
  },
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "viewScript": "file:./view.js"
}
