{
  "apiVersion": 3,
  "name": "aeo-custom-blocks/nav",
  "title": "AEO Navigation Menu",
  "category": "design",
  "icon": "menu",
  "description": "Glassmorphic fixed navigation bar with editable brand text, links, and a highlighted CTA button.",
  "supports": {
    "html": false,
    "align": ["full", "wide"]
  },
  "attributes": {
    "brandText": {
      "type": "string",
      "default": "aeo-copilot"
    },
    "links": {
      "type": "array",
      "default": [
        { "label": "Features", "url": "#features" },
        { "label": "Solutions", "url": "#solutions" },
        { "label": "Pricing", "url": "#pricing" },
        { "label": "Blog", "url": "#blog" }
      ]
    },
    "ctaText": {
      "type": "string",
      "default": "Take a Tour"
    },
    "ctaUrl": {
      "type": "string",
      "default": "#tour"
    }
  },
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "viewScript": "file:./view.js"
}
